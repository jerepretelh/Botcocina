{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "src/shared/**/*.ts",
    "src/app/data/recipes.ts",
    "src/types/index.ts"
  ]
}
