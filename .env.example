VITE_SUPABASE_ENABLED=true
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_FIXED_RUNTIME_STORAGE_MODE=supabase
VITE_SUPABASE_RECIPE_SEEDS_ENABLED=false
VITE_SUPABASE_USER_RECIPE_CONFIGS_ENABLED=false

SUPABASE_ENABLED=true
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Safety: disabled by default in production.
ALLOW_SHEETS_FALLBACK=false

# Emergency import only (optional)
GOOGLE_SHEETS_RECIPES_SHEET_ID=your_sheet_id
GOOGLE_SHEETS_RECIPES_RECIPES_GID=0
GOOGLE_SHEETS_RECIPES_INGREDIENTS_GID=0
GOOGLE_SHEETS_RECIPES_SUBSTEPS_GID=0

# Optional: server-side encryption key for user BYOK AI settings
AI_CONFIG_ENCRYPTION_KEY=change_me_to_a_long_random_secret

# Optional: platform-wide Gemini fallback key
GOOGLE_API_KEY=your_google_api_key

# Optional: local AI mock mode for frontend testing without consuming tokens
VITE_AI_MOCK_MODE=false
