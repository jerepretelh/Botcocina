{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test:unit": "tsx --test src/**/*.test.ts src/**/*.test.tsx",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:headed": "playwright test --headed --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui --pass-with-no-tests",
    "test:e2e:ai-smoke": "playwright test e2e/specs/ai-recipe-generation-smoke.spec.ts --pass-with-no-tests",
    "test:e2e:prod:smoke": "playwright test e2e/specs/product-production-smoke.spec.ts --pass-with-no-tests",
    "test:e2e:capabilities": "playwright test e2e/specs/recipe-capability-smoke.spec.ts --pass-with-no-tests",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:auth:generate": "bash scripts/playwright/generate_storage_state.sh",
    "typecheck:vercel-api": "tsc -p tsconfig.api.json --noEmit",
    "catalog:validate": "tsx scripts/validate_catalog.ts",
    "seed:catalog:generate": "tsx scripts/generate_catalog_seed_sql.ts",
    "catalog:release:prepare": "npm run catalog:validate && npm run seed:catalog:generate",
    "catalog:push": "tsx scripts/push_catalog_to_supabase.ts",
    "import:recipes:sheets": "tsx scripts/import_recipes_from_sheets.ts"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
